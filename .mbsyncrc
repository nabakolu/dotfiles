	Inbox ~/mail/nabakolu/INBOX
	SubFolders Verbatim

Channel nabakolu
	Far :nabakolu-remote:
	Near :nabakolu-local:
	Create Both # automatically create missing mailboxes on server and locally
	Syncstate * # Save the synchronization state files in the relevant directory
	Patterns * # Include everything
	ExpireUnread no
